# ============================================================
# Claude Telegram Relay — Environment Variables
# ============================================================
# Copy to .env:  cp .env.example .env
# Then fill in your values below.
# ============================================================

# --- REQUIRED: Telegram ---

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your Telegram user ID (from @userinfobot)
TELEGRAM_USER_ID=your_telegram_user_id

# --- REQUIRED: Supabase (persistent memory) ---

# Project URL (looks like https://abc123.supabase.co)
SUPABASE_URL=your_project_url

# anon public key (starts with eyJ...)
SUPABASE_ANON_KEY=your_anon_key

# --- RECOMMENDED: Personalization ---

# Your first name
USER_NAME=Your Name

# Your timezone (IANA format: America/New_York, Europe/Berlin, etc.)
USER_TIMEZONE=UTC

# --- REQUIRED: Anthropic API Key ---

# API key from console.anthropic.com (replaces Claude CLI OAuth)
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- OPTIONAL: MCP — Google Calendar ---

# Path to the Google Calendar MCP directory (calendar_mcp.py)
# GOOGLE_CALENDAR_MCP_PATH=/home/ubuntu/Google_Calendar_MCP
# GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
# UV_PATH=/home/ubuntu/.local/bin/uv

# --- OPTIONAL: MCP — MS365 Personal (e.g. hotmail/outlook personal account) ---

# MS365_PERSONAL_CLIENT_ID=your_client_id
# MS365_PERSONAL_TOKEN_CACHE=~/.ms365-personal-token-cache.json
# MS365_PERSONAL_ACCOUNT_PATH=~/.ms365-personal-account.json

# --- OPTIONAL: MCP — MS365 Business ---

# MS365_BUSINESS_CLIENT_ID=your_client_id
# MS365_BUSINESS_TENANT_ID=your_tenant_id
# MS365_BUSINESS_TOKEN_CACHE=~/.ms365-business-token-cache.json
# MS365_BUSINESS_ACCOUNT_PATH=~/.ms365-business-account.json

# --- OPTIONAL: Paths ---

# Relay data directory (defaults to ~/.claude-relay)
# RELAY_DIR=~/.claude-relay

# Path to bun binary (used by reminder-scheduler MCP, defaults to "bun")
# BUN_PATH=/home/ubuntu/.bun/bin/bun

# --- OPTIONAL: Morning Briefing ---

# Delivery channel: "telegram" (default), "phone", or "both"
# BRIEFING_DELIVERY=telegram

# Location for weather in morning briefing (latitude/longitude)
# Defaults to Trowbridge, UK if not set
# WEATHER_LAT=51.3205
# WEATHER_LON=-2.2087

# --- OPTIONAL: Voice Transcription (speech-to-text, incoming voice messages) ---

# Voice provider: "groq" (free cloud API) or "local" (whisper.cpp on your machine)
# VOICE_PROVIDER=groq

# For Groq: Free API key from console.groq.com
# GROQ_API_KEY=your_groq_key

# --- OPTIONAL: Voice Replies (text-to-speech, bot responds with voice notes) ---

# OpenAI API key — also used for embeddings if you set that up via Supabase
# When set, the bot will reply to voice messages with a voice note (mirror mode)
# OPENAI_API_KEY=your_openai_key

# Voice to use for TTS (alloy, echo, fable, onyx, nova, shimmer) — default: alloy
# TTS_VOICE=alloy

# For local whisper.cpp:
# WHISPER_BINARY=whisper-cpp
# WHISPER_MODEL_PATH=~/whisper-models/ggml-base.en.bin

# --- OPTIONAL: Phone (Twilio) ---

# Twilio Account SID (from twilio.com/console)
# TWILIO_ACCOUNT_SID=your_account_sid

# Twilio Auth Token (from twilio.com/console)
# TWILIO_AUTH_TOKEN=your_auth_token

# Your Twilio phone number (E.164 format: +1234567890)
# TWILIO_PHONE_NUMBER=+1234567890

# Your personal phone number (for outbound calls and caller verification)
# USER_PHONE_NUMBER=+1234567890

# Port for the Twilio webhook HTTP server (default: 3100)
# PHONE_WEBHOOK_PORT=3100

# Public URL for Twilio webhooks (default: http://<your-ip>:<port>)
# PHONE_WEBHOOK_URL=http://your-server-ip:3100
